# MedVision Frontend — Environment Variables
# Copy this file to .env and fill in real values.

# Cloud Run backend URL (required in production)
# Get this from: gcloud run services describe medvision --region us-central1 --format "value(status.url)"
VITE_CLOUD_RUN_URL=https://medvision-xxxxxxxxxx-uc.a.run.app

# GCP region displayed in the status bar (cosmetic only)
VITE_GCP_REGION=us-central1
