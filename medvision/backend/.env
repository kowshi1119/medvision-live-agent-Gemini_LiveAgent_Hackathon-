# MedVision Backend — Environment Variables

# ── Gemini / Google AI API key ─────────────────────────────────────────────
# Get your free key from: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY is used by google-adk; GEMINI_API_KEY is a legacy alias.
GOOGLE_API_KEY=your_actual_key_from_aistudio.google.com
GEMINI_API_KEY=your_actual_key_from_aistudio.google.com

# ── GCP (production / Cloud Run) ───────────────────────────────────────────
# When set, Vertex AI is used instead of the API key above.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Cloud Storage bucket for session logs ──────────────────────────────────
# Default auto-generated as: medvision-session-logs-{PROJECT_ID}
MEDVISION_SESSION_BUCKET=medvision-session-logs-your-gcp-project-id

# ── CORS: allowed frontend origin ──────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ── Server port ────────────────────────────────────────────────────────────
PORT=8080
