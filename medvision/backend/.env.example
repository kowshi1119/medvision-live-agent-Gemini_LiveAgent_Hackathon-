# MedVision Backend — Environment Variables
# Copy this file to .env and fill in real values.

# ── Gemini API key (local dev / AI Studio) ─────────────────────────────────
# Get your free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_actual_key_from_aistudio.google.com

# ── GCP (production / Cloud Run) ───────────────────────────────────────────
# When set, Vertex AI is used instead of the API key above.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Cloud Storage bucket for session logs ──────────────────────────────────
# Default auto-generated as: medvision-session-logs-{PROJECT_ID}
MEDVISION_SESSION_BUCKET=medvision-session-logs-your-gcp-project-id

# ── CORS: allowed frontend origin ──────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ── Server port ────────────────────────────────────────────────────────────
PORT=8080

# ── MedGemma 4B (local NVIDIA GPU, optional) ───────────────────────────────
# 1. Accept model terms at: https://huggingface.co/google/medgemma-4b-it
# 2. Generate a token at: https://huggingface.co/settings/tokens
# 3. Set the vars below and restart the backend
MEDGEMMA_ENABLED=false
HUGGINGFACE_TOKEN=your_huggingface_token_here
# MEDGEMMA_DEVICE=cuda   # or "cpu" for CPU-only inference
# MEDGEMMA_MODEL_PATH=C:/path/to/medgemma-4b-it   # use a local git clone instead of HF Hub download
